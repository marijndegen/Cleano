<Window x:Class="Cleano.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cleano"
        xmlns:converters="clr-namespace:Cleano.Converters"
        mc:Ignorable="d"
        Title="Clearo - Cleaning Checklist Manager" Height="600" Width="900">
    <Window.Resources>
        <converters:TaskSortConverter x:Key="TaskSortConverter"/>
    </Window.Resources>
    <TabControl>
        <!-- User Tab -->
        <TabItem Header="User View">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Task Groups and Tasks -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SortedTaskGroups}" Margin="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="1" Margin="0,0,0,15" Padding="10" CornerRadius="5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding Tasks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="5,3" Margin="0,2">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" FontSize="14"/>
                                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="10,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="{Binding Frequency}"/>
                                                                        <Setter Property="Foreground" Value="Gray"/>
                                                                        <Setter Property="FontSize" Value="12"/>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="11">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                                <Setter Property="Text" Value="⚠ OVERDUE"/>
                                                                                <Setter Property="Foreground" Value="Red"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsOverdue}" Value="False">
                                                                                <Setter Property="Text" Value="✓ Current"/>
                                                                                <Setter Property="Foreground" Value="Green"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Print Button -->
                <Border Grid.Row="1" Background="#F5F5F5" Padding="15" BorderBrush="LightGray" BorderThickness="0,1,0,0">
                    <Button Command="{Binding PrintCommand}" 
                            Content="🖨 Generate PDF and Mark as Complete" 
                            FontSize="14" 
                            Padding="20,10" 
                            Background="#4CAF50" 
                            Foreground="White" 
                            BorderThickness="0" 
                            Cursor="Hand"
                            HorizontalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="5" 
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#45A049"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Border>
            </Grid>
        </TabItem>

        <!-- Admin Tab -->
        <TabItem Header="Admin Settings">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Task Groups -->
                <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,0,5,0" CornerRadius="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Task Groups" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <StackPanel Grid.Row="1" Margin="0,0,0,10">
                            <TextBox Text="{Binding NewGroupName, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="5" 
                                     Margin="0,0,0,5"
                                     FontSize="13"/>
                            <Button Command="{Binding AddGroupCommand}" 
                                    Content="+ Add Group" 
                                    Padding="8,5" 
                                    Background="#2196F3" 
                                    Foreground="White" 
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="3" 
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1976D2"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <ListBox Grid.Row="2" 
                                 ItemsSource="{Binding TaskGroups}" 
                                 SelectedItem="{Binding SelectedAdminGroup}"
                                 FontSize="13">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 FontSize="13"
                                                 VerticalAlignment="Center"
                                                 Padding="5,2"
                                                 x:Name="GroupNameTextBox">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="IsReadOnly" Value="True"/>
                                                    <Setter Property="Cursor" Value="Arrow"/>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="5,0,0,0">
                                            <Button Content="✏️" 
                                                    ToolTip="Edit"
                                                    Padding="5,2"
                                                    Margin="0,0,3,0"
                                                    Background="Transparent"
                                                    BorderThickness="1"
                                                    BorderBrush="#2196F3"
                                                    Cursor="Hand"
                                                    Click="EditGroupButton_Click"
                                                    Tag="{Binding ElementName=GroupNameTextBox}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" 
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="3" 
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <Button Content="🗑️" 
                                                    ToolTip="Delete"
                                                    Padding="5,2"
                                                    Background="Transparent"
                                                    BorderThickness="1"
                                                    BorderBrush="#F44336"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.DeleteGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" 
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="3" 
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FFEBEE"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Right Panel: Tasks -->
                <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="5,0,0,0" CornerRadius="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold" Margin="0,0,0,10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Select a group"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedAdminGroup}" Value="{x:Null}">
                                            <Setter Property="Text" Value="Select a group"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Tasks in {0}">
                                    <Binding Path="SelectedAdminGroup.Name" FallbackValue="Select a group"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <StackPanel Grid.Row="1" Margin="0,0,0,10">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedAdminGroup}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBox Text="{Binding NewTaskName, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="5" 
                                     Margin="0,0,0,5"
                                     FontSize="13"/>

                            <ComboBox ItemsSource="{Binding FrequencyOptions}" 
                                      SelectedItem="{Binding SelectedFrequency}"
                                      Padding="5"
                                      Margin="0,0,0,5"
                                      FontSize="13"/>

                            <Button Command="{Binding AddTaskCommand}" 
                                    Content="+ Add Task" 
                                    Padding="8,5" 
                                    Background="#4CAF50" 
                                    Foreground="White" 
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="3" 
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#45A049"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <ListBox Grid.Row="2" ItemsSource="{Binding SelectedAdminGroup.Tasks}" FontSize="13">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.RowSpan="2">
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                     FontWeight="SemiBold"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     VerticalAlignment="Center"
                                                     Padding="5,2"
                                                     x:Name="TaskNameTextBox">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="IsReadOnly" Value="True"/>
                                                        <Setter Property="Cursor" Value="Arrow"/>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <TextBlock Text="{Binding Frequency, StringFormat='Frequency: {0}'}" 
                                                       FontSize="11" 
                                                       Foreground="Gray"
                                                       Margin="5,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="5,0,0,0" VerticalAlignment="Center">
                                            <Button Content="✏️" 
                                                    ToolTip="Edit"
                                                    Padding="5,2"
                                                    Margin="0,0,3,0"
                                                    Background="Transparent"
                                                    BorderThickness="1"
                                                    BorderBrush="#2196F3"
                                                    Cursor="Hand"
                                                    Click="EditTaskButton_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" 
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="3" 
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <Button Content="🗑️" 
                                                    ToolTip="Delete"
                                                    Padding="5,2"
                                                    Background="Transparent"
                                                    BorderThickness="1"
                                                    BorderBrush="#F44336"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" 
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="3" 
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FFEBEE"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
